# LettuceCache environment configuration
# Copy this file to .env and fill in the values.

# OpenAI API key — required for LLM calls
OPENAI_API_KEY=sk-...

# Redis connection
REDIS_HOST=localhost
REDIS_PORT=6379

# Embedding sidecar
EMBED_URL=http://localhost:8001
EMBED_DIM=384
EMBED_MODEL_NAME=all-MiniLM-L6-v2
EMBED_WORKERS=2

# HTTP server
HTTP_PORT=8080

# FAISS index persistence path (inside container / local)
FAISS_INDEX_PATH=./faiss.index
